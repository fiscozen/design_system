#!/bin/sh

# ── Changeset check ─────────────────────────────────────────────────────────
# Ensures that changes to packages/ are accompanied by a changeset file.
# Skip with: SKIP_CHANGESET_CHECK=1 git push
# ─────────────────────────────────────────────────────────────────────────────

SKIP_CHANGESET=0
BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$SKIP_CHANGESET_CHECK" = "1" ]; then
  echo "⏭  Changeset check skipped (SKIP_CHANGESET_CHECK=1)"
  SKIP_CHANGESET=1
elif [ "$BRANCH" = "main" ]; then
  SKIP_CHANGESET=1
elif ! git rev-parse --verify origin/main >/dev/null 2>&1; then
  echo "⚠  origin/main not found — skipping changeset check"
  SKIP_CHANGESET=1
fi

if [ "$SKIP_CHANGESET" = "0" ]; then
  MERGE_BASE=$(git merge-base origin/main HEAD 2>/dev/null || echo "origin/main")
  CHANGED_PACKAGE_FILES=$(git diff --name-only "$MERGE_BASE"...HEAD -- 'packages/*/src/' 2>/dev/null)

  if [ -n "$CHANGED_PACKAGE_FILES" ]; then
    CHANGESET_FILES=$(git diff --name-only "$MERGE_BASE"...HEAD -- '.changeset/*.md' 2>/dev/null | grep -v README.md)

    if [ -z "$CHANGESET_FILES" ]; then
      echo ""
      echo "🚨 Changeset mancante!"
      echo ""
      echo "   Hai modificato sorgenti in packages/ ma non hai aggiunto un changeset."
      echo ""
      echo "   Pacchetti modificati:"
      echo "$CHANGED_PACKAGE_FILES" | sed 's|packages/\([^/]*\)/.*|     \1|' | sort -u
      echo ""
      echo "   Per aggiungere un changeset:"
      echo "     pnpm changeset"
      echo ""
      echo "   Per skippare questo check (solo se sai cosa fai):"
      echo "     SKIP_CHANGESET_CHECK=1 git push"
      echo ""
      exit 1
    fi
  fi
fi

# ── Production dependency audit ────────────────────────────────────────────────
# Blocks pushes that introduce HIGH/CRITICAL vulnerabilities in PRODUCTION
# dependencies — the published surface that ships to consuming apps. Dev/build-
# tool advisories are intentionally NOT gated here (they do not propagate).
# Skip with: SKIP_AUDIT_CHECK=1 git push
# ─────────────────────────────────────────────────────────────────────────────

if [ "$SKIP_AUDIT_CHECK" = "1" ]; then
  echo "⏭  Prod audit check skipped (SKIP_AUDIT_CHECK=1)"
else
  echo "🔒 Auditing production dependencies..."
  pnpm audit --prod --audit-level high
  AUDIT_EXIT=$?
  if [ $AUDIT_EXIT -ne 0 ]; then
    echo ""
    echo "🚨 High/critical vulnerabilities in PRODUCTION dependencies!"
    echo "   These ship to consumers — fix before pushing."
    echo ""
    echo "   To skip this check (only if you know what you're doing):"
    echo "     SKIP_AUDIT_CHECK=1 git push"
    echo ""
    exit 1
  fi
fi

# ── Build check ──────────────────────────────────────────────────────────────
# Builds all packages to catch transitive breakage.
# Skip with: SKIP_BUILD_CHECK=1 git push
# ─────────────────────────────────────────────────────────────────────────────

if [ "$SKIP_BUILD_CHECK" = "1" ]; then
  echo "⏭  Build check skipped (SKIP_BUILD_CHECK=1)"
else
  echo "🔨 Building all packages..."
  pnpm nx run-many -t build
  BUILD_EXIT=$?
  if [ $BUILD_EXIT -ne 0 ]; then
    echo ""
    echo "🚨 Build failed! Fix build errors before pushing."
    echo ""
    echo "   To skip this check (only if you know what you're doing):"
    echo "     SKIP_BUILD_CHECK=1 git push"
    echo ""
    exit 1
  fi
fi

# ── Storybook interaction tests ──────────────────────────────────────────────
# Runs play-function tests to catch DOM selector / rendering regressions.
# Skip with: SKIP_STORYBOOK_CHECK=1 git push
# ─────────────────────────────────────────────────────────────────────────────

if [ "$SKIP_STORYBOOK_CHECK" = "1" ]; then
  echo "⏭  Storybook interaction tests skipped (SKIP_STORYBOOK_CHECK=1)"
else
  echo "🎭 Running Storybook interaction tests..."
  pnpm --filter @fiscozen/storybook run test:storybook
  STORYBOOK_EXIT=$?
  if [ $STORYBOOK_EXIT -ne 0 ]; then
    echo ""
    echo "🚨 Storybook interaction tests failed! Fix play-function tests before pushing."
    echo ""
    echo "   To skip this check (only if you know what you're doing):"
    echo "     SKIP_STORYBOOK_CHECK=1 git push"
    echo ""
    exit 1
  fi
fi

exit 0
