  <ol class="m-0 flex list-none gap-1 p-0">
    <li class="flex items-center gap-1"><a aria-current="page" href="/" class="router-link-active router-link-exact-active text-blue-500">home</a><span aria-hidden="true"><span class="text-grey-300">/</span></span></li>
    <li class="flex items-center gap-1"><a href="/foo" class="text-blue-500">foo</a><span aria-hidden="true"><span class="text-grey-300">/</span></span></li>
