{
  "name": "@fiscozen/design_system",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "//test-and-build": "test/build scripts pass --exclude='tag:deprecated' so Nx projects tagged 'deprecated' (see packages/<name>/project.json) are skipped. They are frozen at their last published version and don't need to run on every test/build.",
  "scripts": {
    "test": "nx run-many --target=test:unit --exclude='tag:deprecated'",
    "test:unit": "nx run-many --target=test:unit --exclude='tag:deprecated'",
    "test:coverage": "nx run-many --target=test:unit --exclude='tag:deprecated' -- --coverage",
    "test:affected": "nx affected -t test:unit --exclude='tag:deprecated'",
    "build": "nx run-many --target=build --exclude='tag:deprecated'",
    "storybook": "nx run @fiscozen/storybook:storybook",
    "generate:component": "plop component",
    "test:storybook": "cd apps/storybook && pnpm test:storybook",
    "test:storybook:watch": "cd apps/storybook && pnpm test:storybook:watch",
    "test:storybook:coverage": "cd apps/storybook && pnpm test:storybook:coverage",
    "test:storybook:ui": "cd apps/storybook && pnpm test:storybook --ui",
    "prepare": "husky",
    "release:check": "node scripts/release-check.mjs",
    "release:check:unpublished": "node scripts/release-check.mjs --unpublished",
    "release:check:pending": "node scripts/release-check.mjs --pending",
    "release:check:graph": "node scripts/release-check.mjs --graph",
    "release:check:health": "node scripts/release-check.mjs --health",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version"
  },
  "engines": {
    "pnpm": "^10",
    "node": "^22.12.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "husky": "^9.1.7",
    "nx": "20.7.1",
    "plop": "^4.0.1",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "glob": "^11.1.0"
    }
  }
}
